' ══════════════════════════════════════════════
'  PRESENTATION — BLOC / CUBITS
' ══════════════════════════════════════════════

package "Presentation / BLoC" #EDF2F7 {

    together {
        class AuthBloc {
            - _loginUseCase    : LoginUseCase
            - _registerUseCase : RegisterUseCase
            - _authRepository  : AuthRepository
            + add(AuthEvent)
        }

        class ForgotPasswordBloc {
            - _useCase : ForgotPasswordUseCase
            + add(ForgotPasswordEvent)
        }

        class ResetPasswordBloc {
            - _useCase : ResetPasswordUseCase
            + add(ResetPasswordEvent)
        }
    }

    together {
        class WorkoutsCubit {
            - _getPage    : GetWorkoutsPageUseCase
            + load()      : Future<void>
            + refresh()   : Future<void>
            + loadMore()  : Future<void>
            + applyFilters(search, type?, complexity?) : Future<void>
        }

        class WorkoutDetailCubit {
            - _getById : GetWorkoutByIdUseCase
            + load(id) : Future<void>
        }

        class ExercisesCubit {
            - _getPage   : GetExercisesPageUseCase
            + load()     : Future<void>
            + refresh()  : Future<void>
            + loadMore() : Future<void>
            + applyFilters(search, complexity?) : Future<void>
        }

        class ExerciseDetailCubit {
            - _getById : GetExerciseByIdUseCase
            + load(id) : Future<void>
        }
    }

    together {
        class ProfileCubit {
            - _getProfile    : GetProfileUseCase
            - _getGoals      : GetGoalsUseCase
            - _updateProfile : UpdateProfileUseCase
            + load()                          : Future<void>
            + save(UpdateProfileParams)       : Future<void>
        }

        class TrainingCalendarCubit {
            - _getWorkouts        : GetWorkoutsUseCase
            - _calendarRepository : WorkoutCalendarRepository
            + load(DateTime)                        : Future<void>
            + scheduleWorkout(workoutId, date)      : Future<void>
            + setEntryCompleted(entity, bool)       : Future<void>
            + deleteEntry(id)                       : Future<void>
        }

        class AiRecommendationsCubit {
            - _useCase : GetAiRecommendationsUseCase
            + load()   : Future<void>
        }
    }
}

AuthBloc              ..>  LoginUseCase
AuthBloc              ..>  RegisterUseCase
AuthBloc              ..>  AuthRepository
ForgotPasswordBloc    ..>  ForgotPasswordUseCase
ResetPasswordBloc     ..>  ResetPasswordUseCase
WorkoutsCubit         ..>  GetWorkoutsPageUseCase
WorkoutDetailCubit    ..>  GetWorkoutByIdUseCase
ExercisesCubit        ..>  GetExercisesPageUseCase
ExerciseDetailCubit   ..>  GetExerciseByIdUseCase
ProfileCubit          ..>  GetProfileUseCase
ProfileCubit          ..>  UpdateProfileUseCase
ProfileCubit          ..>  GetGoalsUseCase
TrainingCalendarCubit ..>  WorkoutCalendarRepository
AiRecommendationsCubit ..> GetAiRecommendationsUseCase

