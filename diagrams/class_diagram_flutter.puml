        }

        class TrainingCalendarPage {
            + build() : Widget
        }
    }

    together {
        class ProfilePage {
            + build() : Widget
        }

        class AiRecommendationsPage {
            + build() : Widget
        }

        class AccountCredentialsPage {
            + build() : Widget
        }
    }
}

